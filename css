.cabecalho { 
  background-color: #7e3e1c; 
  text-decoration: none;
  padding: 15px 25px; 
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
} 
body { 
  display: flex; 
  flex-direction: column; 
  min-height: 100vh; 
  background-color: #f5f2f2; 
} 
main { 
  flex: 1;
} 
h1 { 
  color: #fff; 
  font-size: 24px; 
} 
footer { 
  background-color: #7e3e1c; 
  padding: 15px 25px; 
  color: #fff; 
} 
.cartao-interno { 
  position: relative; 
  transition: transform 0.8s; 
  transform-style: preserve-3d; 
} 
.cartao-frente, 
.cartao-verso { 
  transform: rotateY(180deg);
  position: absolute; 
  border-radius: 12px; 
  box-shadow: 0 6px 12px rgba(0, 0, 0, 0.15); 
  backface-visibility: hidden; 
}
.cartao:hover .cartao-interno { 
  transform: rotateY(180deg); 
} section { 
  display: flex; 
  gap: 16px; 
} 
