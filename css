.cabecalho { 
  background-color: #7e3e1c; 
  text-decoration: none;
  padding: 15px 25px; 
  display: flex; 
  justify-content: space-between; 
  align-items: center; 
} 
body { 
  display: flex; 
  flex-direction: column; 
  min-height: 100vh; 
  background-color: #f5f2f2; 
} 
main { 
  flex: 1;
} 
h1 { 
  color: #fff; 
  font-size: 24px; 
} 
footer { 
  background-color: #7e3e1c; 
  padding: 15px 25px; 
  color: #fff; 
} 
